// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  firstName     String?
  lastName      String?
  role          String    @default("user")
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  kycApplications KYCApplication[]
  adminUser     AdminUser?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AdminUser {
  id        String   @id @default(cuid())
  userId    String   @unique
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User            @relation(fields: [userId], references: [id])
  reviews    KYCApplication[]
  reviewHistory KYCReviewHistory[]
}

model KYCApplication {
  id                    String   @id @default(cuid())
  userId                String
  status                KYCStatus @default(PENDING)
  
  // Document references
  businessLicenseKey   String?
  taxIdDocumentKey     String?
  governmentIdKey      String?
  
  // Submitted data
  businessName         String
  taxIdNumber          String
  businessAddress      String
  
  // Review tracking
  reviewedBy           String?
  reviewedAt           DateTime?
  rejectionReason      String?
  reviewerNotes        String?
  
  // Timestamps
  submittedAt          DateTime @default(now())
  approvedAt           DateTime?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id])
  reviewer     AdminUser?        @relation(fields: [reviewedBy], references: [userId])
  reviewHistory KYCReviewHistory[]

  @@index([status])
  @@index([userId])
  @@index([submittedAt])
}

model KYCReviewHistory {
  id            String   @id @default(cuid())
  applicationId String
  reviewerId    String
  action        String
  notes         String?
  createdAt     DateTime @default(now())

  application KYCApplication @relation(fields: [applicationId], references: [id])
  reviewer    AdminUser      @relation(fields: [reviewerId], references: [userId])
}

enum KYCStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  NEEDS_INFO
}
